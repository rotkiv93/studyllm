{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "studyllm",
  "version": "0.2.0",
  "identifier": "com.studyllm",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "studyllm",
        "width": 1000,
        "height": 720,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data: asset: https://asset.localhost; font-src 'self' data:; connect-src 'self' https: ipc: http://ipc.localhost; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVEOTk3NTJCMjUyMDYwQwpSV1FNQmxLeVVwZlpEbUliSFB5ZUZ2c1VGNUVieHUrYU5wcGNocjBPSFZxbnVJVjZQQ0ZPb3l4Vwo=",
      "endpoints": [
        "https://github.com/rotkiv93/studyllm/releases/latest/download/latest.json"
      ]
    }
  }
}
